---
// Header — responsive navigation chrome (D-07, D-08).
// Mobile (<768px): wordmark · Contact button + hamburger; 4 links in NavDrawer.
// Desktop (>=768px): wordmark · inline nav · Contact button; no hamburger.
// All NAP/contact strings come from business.ts (D-15) — none hardcoded here.
import { business } from '../data/business';
import NavDrawer from './NavDrawer.astro';

const path = Astro.url.pathname;
const here = path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

// "Renovart Interiors" → split so "Interiors" gets the accent tint (D-08).
const [brandLead, ...brandRest] = business.name.split(' ');
const brandAccent = brandRest.join(' ');

const navLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/servicii', label: 'Servicii' },
  { href: '/lucrari', label: 'Lucrări' },
  { href: '/ghiduri', label: 'Ghiduri' },
  { href: '/despre', label: 'Despre' },
  { href: '/cariere', label: 'Cariere' },
];
---

<header class="header">
  <a href="/" class="wordmark" aria-label={`${business.name} — Acasă`}>
    <span class="wordmark__lead">{brandLead}</span>
    {brandAccent && <span class="wordmark__accent">{' '}{brandAccent}</span>}
  </a>

  <nav class="desktop-nav" aria-label="Navigație principală">
    <ul>
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={here === href ? 'page' : undefined}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="header__actions">
    <a href="/contact" class="contact-btn" aria-current={here === '/contact' ? 'page' : undefined}>
      Contact
    </a>

    <button
      type="button"
      class="hamburger"
      aria-label="Meniu"
      aria-expanded="false"
      aria-controls="navDrawer"
      data-drawer-toggle
    >
      <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<NavDrawer />

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    min-height: 56px;
    padding: 0 var(--space-md);
    background: var(--color-slate-800);
    color: var(--color-on-dark);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--color-on-dark);
    text-decoration: none;
  }

  .wordmark__accent {
    color: var(--color-accent-300);
  }

  .desktop-nav {
    display: none;
  }

  .desktop-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-lg);
  }

  .desktop-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    color: var(--color-on-dark);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .desktop-nav a:hover {
    color: var(--color-accent-300);
  }

  .desktop-nav a[aria-current='page'] {
    box-shadow: inset 0 -2px 0 0 var(--color-accent-300);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 var(--space-md);
    background: var(--color-accent);
    color: var(--color-on-dark);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: var(--radius-sm);
  }

  .contact-btn:hover {
    background: var(--color-accent-hover);
  }

  /* WR-05: give aria-current="page" a visible indicator (it had none). Darken
     to the active/hover terracotta and add an inset bottom marker mirroring the
     nav-link active treatment. */
  .contact-btn[aria-current='page'] {
    background: var(--color-accent-hover);
    box-shadow: inset 0 -2px 0 0 var(--color-on-dark);
  }

  .hamburger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: transparent;
    border: none;
    color: var(--color-on-dark);
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  /* Doubled focus ring for visibility on the dark header surface. */
  .wordmark:focus-visible,
  .desktop-nav a:focus-visible,
  .contact-btn:focus-visible,
  .hamburger:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 2px;
    box-shadow: 0 0 0 5px var(--color-accent-300);
  }

  /* Desktop step-up: show inline nav, hide hamburger (drawer hidden via CSS). */
  @media (min-width: 768px) {
    .header {
      padding: 0 var(--space-lg);
    }
    .desktop-nav {
      display: block;
    }
    .hamburger {
      display: none;
    }
  }
</style>
