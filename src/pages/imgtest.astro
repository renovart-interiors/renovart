---
// THROWAWAY IMG-01 proof route (kept off the nav). Proves the Pattern A image
// pipeline end-to-end exactly as Phase 2's `lucrari` collection will: load a
// content entry whose frontmatter cover was resolved by the image() helper, then
// render it via <Picture formats={['avif','webp']}> so astro:assets emits AVIF +
// WebP with a responsive srcset and explicit dimensions (anti-CLS).
// Using a dedicated /imgtest route (not index.astro) keeps this proof isolated;
// the route is throwaway — see 01-03-SUMMARY.md for the keep/delete decision.
import { Picture } from 'astro:assets';
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('imgtest', 'sample');
if (!entry) {
  throw new Error('imgtest/sample entry not found — IMG-01 proof cannot render');
}
---

<BaseLayout title="IMG-01 proof — astro:assets Pattern A">
  <Fragment slot="head">
    {/* WR-07: throwaway debug route — keep it out of search indexes while it
        exists. Phase 2 gate: delete this page, the imgtest collection, and
        src/content/imgtest/ before shipping. */}
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <h1>IMG-01 proof</h1>
  <p>
    Imaginea de mai jos provine dintr-o colecție de conținut, rezolvată prin
    helper-ul <code>image()</code> și optimizată de <code>astro:assets</code>.
  </p>
  <Picture
    src={entry.data.cover}
    formats={['avif', 'webp']}
    widths={[400, 800, 1200]}
    sizes="(max-width: 800px) 100vw, 800px"
    alt="Test imagine optimizare astro:assets"
    loading="eager"
  />
</BaseLayout>
